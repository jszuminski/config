[user]
	name = jszuminski
	email = jszuminski@pm.me
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[pull]
	# plain `git pull` rebases instead of creating merge commits
	rebase = true
[fetch]
	# delete local refs to branches/tags that were removed on the remote
	prune = true
	pruneTags = true
[rebase]
	# stash dirty changes before a rebase, pop them after
	autoStash = true
	# rebasing a branch also moves stacked branches that point into it
	updateRefs = true
[merge]
	# conflict markers include the common-ancestor version (|||||||)
	conflictStyle = zdiff3
[diff]
	algorithm = histogram
	# moved lines render in a different color than added/removed ones
	colorMoved = default
[rerere]
	# remember conflict resolutions and reuse them automatically
	enabled = true
[commit]
	# show the diff inside the commit-message editor
	verbose = true
[branch]
	# `git branch` lists most recently committed branches first
	sort = -committerdate
[help]
	# "did you mean X?" with a y/n prompt instead of a hard error
	autocorrect = prompt
[core]
	pager = delta
	# ~/.config/git/ignore is the XDG default, set explicitly for clarity
	excludesFile = ~/.config/git/ignore
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
